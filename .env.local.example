# App URL (used to build links in emails)
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# Azure Postgres Flexible Server (direct connection string)
DATABASE_URL=postgresql://user:password@your-server.postgres.database.azure.com:5432/dbname?sslmode=require

# NextAuth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=your-auth-secret-here

# Microsoft Graph API (mail sending) - Entra ID app registration with
# Mail.Send application permission, scoped to GRAPH_SENDER_EMAIL via an
# Exchange Online Application Access Policy
GRAPH_TENANT_ID=your-tenant-id-here
GRAPH_CLIENT_ID=your-app-registration-client-id-here
GRAPH_CLIENT_SECRET=your-client-secret-here
GRAPH_SENDER_EMAIL=admin@farnboroughfc-fantasy.com

# VAPID keys for Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=admin@farnboroughfc-fantasy.com
